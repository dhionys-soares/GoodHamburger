@page "/products/create"

@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<h3>Novo Produto</h3>

<EditForm Model= "product" OnValidSubmit="SaveProduct">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Nome</label>
        <InputText class="form-control" @bind-Value="product.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Valor</label>
        <InputNumber class="form-control" @bind-Value="product.Price" />
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo</label>
        <InputSelect class="form-control" @bind-Value="product.Type">
            <option value="1">Sanduíche</option>
            <option value="2">Batata</option>
            <option value="3">Bebida</option>
        </InputSelect>
    </div>
    <div>
        <button class="btn btn-success" type="submit">Salvar</button>
        <button class="btn btn-success" type= "button" @onclick="Back">Voltar</button>
    </div>
</EditForm>

@code {
    private ProductModel product = new();

    private async Task SaveProduct()
    {
        var success = await ProductService.CreateAsync(product);

        if (success)
            NavigationManager.NavigateTo("/products");
    }

    private void Back()
    {
        NavigationManager.NavigateTo("/products");
    }
}