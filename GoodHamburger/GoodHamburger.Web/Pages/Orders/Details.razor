@page "/orders/details/{Id:guid}"
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject OrderService OrderService
@inject NavigationManager Navigation

<h3>Detalhes do Pedido</h3>

@if (order is null)
{
    <p>Carregando pedido...</p>
}
else
{
    <div class="card">
        <div class="card-body">
            <p><strong>Id:</strong> @order.Id</p>
            <p><strong>Total:</strong> @order.Total.ToString("C")</p>
            <p><strong>Desconto:</strong> @order.Discount.ToString("C")</p>

            <h5>Itens</h5>

            @if (order.Items is null || !order.Items.Any())
            {
                <p>Nenhum item encontrado.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                    <tr>
                        <th>Produto Id</th>
                        <th>Quantidade</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in order.Items)
                    {
                        <tr>
                            <td>@item.ProductId</td>
                            <td>@item.Quantity</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            <button class="btn btn-secondary" @onclick="Back">Voltar</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrderModel? order;

    protected override async Task OnInitializedAsync()
    {
        order = await OrderService.GetByIdAsync(Id);
    }

    private void Back()
    {
        Navigation.NavigateTo("/orders");
    }
}