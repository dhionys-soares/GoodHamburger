@page "/"

<PageTitle>Home</PageTitle>

<div class="gh-page">
    <section class="gh-hero mb-4">
        <span class="gh-eyebrow">Good Hamburger</span>
        <h1 class="display-5 mt-3 mb-3">Hambúrgueres, combos e pedidos em poucos cliques.</h1>
        <p class="lead mb-4">Gerencie produtos, consulte o cardápio e acompanhe os pedidos do sistema.</p>
        <div class="gh-actions">
            <NavLink class="btn btn-success" href="/menu">Ver cardápio</NavLink>
            <NavLink class="btn btn-secondary" href="/orders/create">Fazer pedido</NavLink>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="gh-card h-100">
                <div class="gh-card-body">
                    <span class="gh-badge">Produtos</span>
                    <h4 class="mt-3">Cadastro completo</h4>
                    <p class="gh-muted mb-0">Crie e organize sanduíches, batatas e bebidas.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="gh-card h-100">
                <div class="gh-card-body">
                    <span class="gh-badge">Menu</span>
                    <h4 class="mt-3">Cardápio separado</h4>
                    <p class="gh-muted mb-0">Exiba os produtos disponíveis por categoria.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="gh-card h-100">
                <div class="gh-card-body">
                    <span class="gh-badge">Pedidos</span>
                    <h4 class="mt-3">Fluxo rápido</h4>
                    <p class="gh-muted mb-0">Monte pedidos e consulte os detalhes calculados.</p>
                </div>
            </div>
        </div>
    </div>
</div>
